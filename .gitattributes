# Default: auto-detect, normalize to LF in the repo, check out using the OS's native line ending.
* text=auto

# Code/text files always use LF in the repo
*.cs            text eol=lf
*.csproj        text eol=lf
*.sln           text eol=lf
*.axaml         text eol=lf
*.xaml          text eol=lf
*.xshd          text eol=lf
*.json          text eol=lf
*.md            text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.editorconfig  text eol=lf
*.resx          text eol=lf
*.settings      text eol=lf
*.py            text eol=lf
*.sh            text eol=lf

# Windows-only batch / PowerShell — keep CRLF
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf

# Binary assets — never touch
*.dll           binary
*.pdb           binary
*.exe           binary
*.ico           binary
*.png           binary
*.jpg           binary
*.gif           binary
*.wav           binary
*.zip           binary
*.mul           binary
*.idx           binary
