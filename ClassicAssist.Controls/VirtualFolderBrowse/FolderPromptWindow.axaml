<Window x:Class="ClassicAssist.Controls.VirtualFolderBrowse.FolderPromptWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resources="clr-namespace:ClassicAssist.Shared.Resources;assembly=ClassicAssist.Shared"
        Background="{DynamicResource ThemeWindowBackgroundBrush}"
        Title="{x:Static resources:Strings.New_Folder}" Height="150" Width="400"
        Topmost="True">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" VerticalAlignment="Center">
            <TextBlock Text="{x:Static resources:Strings.New_Folder}" DockPanel.Dock="Left" Margin="0,0,10,0"
                       VerticalAlignment="Center" />
            <TextBox x:Name="TextBox" Text="{x:Static resources:Strings.New_Folder}" />
        </DockPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{x:Static resources:Strings.OK}" Margin="0,0,10,0" Click="OKOnClick" Padding="25,5" />
            <Button Content="{x:Static resources:Strings.Cancel}" Click="CancelOnClick" Padding="25,5" />
        </StackPanel>
    </Grid>
</Window>
