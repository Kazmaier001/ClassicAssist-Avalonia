<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        ClassicAssist Dark Theme for Avalonia
        
        This replaces the original 1500-line WPF DarkTheme.xaml.
        Avalonia's built-in FluentTheme (Dark variant) provides all control templates.
        We only override the Fluent resource keys to match the ClassicAssist color palette.
    -->

    <!-- ========== Fluent Theme Resource Overrides ========== -->
    <!-- These keys are defined by Avalonia's FluentTheme and control the look of all controls. -->
    <!-- Reference: https://github.com/AvaloniaUI/Avalonia/blob/master/src/Avalonia.Themes.Fluent/Accents/ -->

    <!-- Region/Chrome colors -->
    <Color x:Key="RegionColor">#1E1E1E</Color>
    <SolidColorBrush x:Key="SystemRegionBrush" Color="#1E1E1E" />

    <!-- Accent colors mapped from SelectionColor2Emphasized (#26A0DA) -->
    <Color x:Key="SystemAccentColor">#26A0DA</Color>
    <Color x:Key="SystemAccentColorDark1">#207097</Color>
    <Color x:Key="SystemAccentColorDark2">#17252D</Color>
    <Color x:Key="SystemAccentColorDark3">#0F1A20</Color>
    <Color x:Key="SystemAccentColorLight1">#3DB8F0</Color>
    <Color x:Key="SystemAccentColorLight2">#6DCAF5</Color>
    <Color x:Key="SystemAccentColorLight3">#9EDCF8</Color>

    <!-- Base/Alt layer colors (background tiers) -->
    <Color x:Key="SolidBackgroundFillColorBase">#1E1E1E</Color>
    <Color x:Key="SolidBackgroundFillColorSecondary">#1A1A1A</Color>
    <Color x:Key="SolidBackgroundFillColorTertiary">#151515</Color>
    <Color x:Key="SolidBackgroundFillColorQuarternary">#292929</Color>

    <!-- Layer/Card backgrounds -->
    <Color x:Key="LayerFillColorDefault">#1A1A1A</Color>
    <Color x:Key="LayerFillColorAlt">#151515</Color>
    <Color x:Key="CardBackgroundFillColorDefault">#292929</Color>
    <Color x:Key="CardBackgroundFillColorSecondary">#1E1E1E</Color>

    <!-- Control fills -->
    <Color x:Key="ControlFillColorDefault">#333333</Color>
    <Color x:Key="ControlFillColorSecondary">#292929</Color>
    <Color x:Key="ControlFillColorTertiary">#1E1E1E</Color>
    <Color x:Key="ControlFillColorDisabled">#292929</Color>
    <Color x:Key="ControlFillColorInputActive">#151515</Color>

    <!-- Control stroke/border colors -->
    <Color x:Key="ControlStrokeColorDefault">#4B4B4B</Color>
    <Color x:Key="ControlStrokeColorSecondary">#333333</Color>
    <Color x:Key="CardStrokeColorDefault">#4B4B4B</Color>

    <!-- Text colors -->
    <Color x:Key="TextFillColorPrimary">#F0F0F0</Color>
    <Color x:Key="TextFillColorSecondary">#C4C4C4</Color>
    <Color x:Key="TextFillColorTertiary">#8A8A8A</Color>
    <Color x:Key="TextFillColorDisabled">#626262</Color>

    <!-- Subtle/Transparent fills for hover/pressed states -->
    <Color x:Key="SubtleFillColorTransparent">Transparent</Color>
    <Color x:Key="SubtleFillColorSecondary">#17252D</Color>
    <Color x:Key="SubtleFillColorTertiary">#193644</Color>

    <!-- List/selection accent colors -->
    <Color x:Key="ListLowColor">#17252D</Color>
    <Color x:Key="ListMediumColor">#193644</Color>

    <!-- ========== Additional App-Level Styles ========== -->

    <!-- Window base styling -->
    <SolidColorBrush x:Key="WindowDefaultBackground" Color="#1E1E1E" />

    <!-- Square corners to match WPF look (FluentTheme rounds by default) -->
    <CornerRadius x:Key="ControlCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="OverlayCornerRadius">0</CornerRadius>
    <CornerRadius x:Key="TextControlCornerRadius">0</CornerRadius>

    <!-- Smaller font sizes to match WPF (FluentTheme defaults are 14pt) -->
    <x:Double x:Key="ControlContentThemeFontSize">12</x:Double>
    <x:Double x:Key="FontSizeSmall">10</x:Double>
    <x:Double x:Key="FontSizeNormal">12</x:Double>
    <x:Double x:Key="FontSizeLarge">14</x:Double>

    <!-- FluentTheme-defined font-size resources used by various templates -->
    <x:Double x:Key="BodyTextBlockFontSize">12</x:Double>
    <x:Double x:Key="CaptionTextBlockFontSize">11</x:Double>
    <x:Double x:Key="BodyStrongTextBlockFontSize">12</x:Double>

    <!-- CheckBox "checked" glyph: use a heavy X instead of the FluentTheme checkmark.
         Note: Avalonia 11 FluentTheme uses Segoe Fluent Icons glyphs as the default. -->
    <x:String x:Key="CheckBoxCheckGlyph">&#x2716;</x:String>
    <x:String x:Key="CheckGlyph">&#x2716;</x:String>

    <!-- CheckBox box size: FluentTheme defaults to 20px (with 32 min-height including padding) -->
    <x:Double x:Key="CheckBoxSize">14</x:Double>
    <x:Double x:Key="CheckBoxCheckGlyphSize">10</x:Double>
    <x:Double x:Key="CheckBoxThemeMinHeight">16</x:Double>
    <x:Double x:Key="CheckBoxThemeMinWidth">16</x:Double>

    <!-- TabItem header sizing (FluentTheme uses these explicitly, not just FontSize) -->
    <x:Double x:Key="TabItemHeaderFontSize">11</x:Double>
    <x:Double x:Key="TabItemMinHeight">22</x:Double>
    <x:Double x:Key="TabItemPipeHeight">2</x:Double>

</ResourceDictionary>
