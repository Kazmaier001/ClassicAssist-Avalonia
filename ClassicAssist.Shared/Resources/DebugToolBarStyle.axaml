<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Debug Toolbar Styles for Avalonia
        
        Avalonia does not have a ToolBar control. The debug toolbar is styled
        using a horizontal StackPanel with themed Button/ToggleButton controls.
    -->

    <!-- Toolbar container style (applied to StackPanel) -->
    <Style Selector="StackPanel.debugToolBar">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Spacing" Value="2" />
        <Setter Property="Background" Value="{DynamicResource BackgroundColor4Brush}" />
        <Setter Property="Height" Value="32" />
    </Style>

    <!-- Toolbar button style -->
    <Style Selector="StackPanel.debugToolBar > Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="MinWidth" Value="28" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="StackPanel.debugToolBar > Button:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BackgroundColor5Brush}" />
    </Style>

    <Style Selector="StackPanel.debugToolBar > Button:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BackgroundColor6Brush}" />
    </Style>

    <Style Selector="StackPanel.debugToolBar > Button:disabled /template/ ContentPresenter">
        <Setter Property="Opacity" Value="0.4" />
    </Style>

    <!-- Toolbar toggle button style -->
    <Style Selector="StackPanel.debugToolBar > ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="MinWidth" Value="28" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="StackPanel.debugToolBar > ToggleButton:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SelectionColor1Brush}" />
    </Style>

    <Style Selector="StackPanel.debugToolBar > ToggleButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BackgroundColor5Brush}" />
    </Style>

    <!-- Toolbar separator -->
    <Style Selector="StackPanel.debugToolBar > Separator">
        <Setter Property="Width" Value="1" />
        <Setter Property="Margin" Value="4,4" />
        <Setter Property="Background" Value="{DynamicResource BackgroundColor6Brush}" />
    </Style>

    <!-- Toolbar icon sizing -->
    <Style Selector="StackPanel.debugToolBar > Button > Image">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
    </Style>

    <Style Selector="StackPanel.debugToolBar > ToggleButton > Image">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
    </Style>
</Styles>
