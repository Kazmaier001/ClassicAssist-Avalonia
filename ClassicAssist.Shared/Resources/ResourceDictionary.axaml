<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://ClassicAssist.Shared/Resources/Colours.axaml" />
        <ResourceInclude Source="avares://ClassicAssist.Shared/Resources/DarkTheme.axaml" />
        <ResourceInclude Source="avares://ClassicAssist.Shared/Resources/Icons.axaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Note: DebugToolBarStyle.axaml uses a Styles root and must be included
         via StyleInclude in the consuming app's App.axaml, not here.
         Example: <StyleInclude Source="avares://ClassicAssist.Shared/Resources/DebugToolBarStyle.axaml" /> -->
</ResourceDictionary>
