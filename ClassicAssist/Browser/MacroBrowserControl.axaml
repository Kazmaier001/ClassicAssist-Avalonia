<UserControl x:Class="ClassicAssist.Browser.MacroBrowserControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ValueConverters="clr-namespace:ClassicAssist.UI.Misc.ValueConverters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:resources="clr-namespace:ClassicAssist.Shared.Resources;assembly=ClassicAssist.Shared"
             xmlns:avalonedit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Xaml.Behaviors.Interactivity"
             xmlns:misc="clr-namespace:ClassicAssist.UI.Misc"
             xmlns:data="clr-namespace:ClassicAssist.Browser.Data"
             xmlns:browser="clr-namespace:ClassicAssist.Browser"
             xmlns:controls2="clr-namespace:ClassicAssist.Controls;assembly=ClassicAssist.Controls"
             xmlns:headered="clr-namespace:ClassicAssist.Controls.Headered;assembly=ClassicAssist.Controls"
             xmlns:behaviours="clr-namespace:ClassicAssist.UI.Misc.Behaviours"
             d:DesignHeight="550" d:DesignWidth="900">
    <UserControl.DataContext>
        <browser:MacroBrowserViewModel />
    </UserControl.DataContext>
    <UserControl.Resources>
        <ResourceDictionary>
            <ValueConverters:BoolToIsVisibleConverter x:Key="BoolToIsVisibleConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <UserControl.Styles>
        <StyleInclude Source="avares://ClassicAssist.Shared/Resources/DebugToolBarStyle.axaml" />
        <StyleInclude Source="../Resources/DarkTheme.axaml" />
        <StyleInclude Source="../Resources/LeftRightIconToggleButton.axaml" />

        <!-- Macros list (left pane): match the WPF reference. WPF
             ListBoxBackgroundBrush = #151515 (same as TreeView), 1-dip
             #4B4B4B border, scrollbar always visible with a Padding
             gutter on the right so item text doesn't render under it.
             Mirrors the TreeView pattern in DarkTheme.axaml. -->
        <Style Selector="ListBox#listBox">
            <Setter Property="Background" Value="#151515" />
            <Setter Property="BorderBrush" Value="#4B4B4B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible" />
            <Setter Property="Padding" Value="0,0,18,0" />
        </Style>
        <Style Selector="ListBox#listBox ScrollViewer">
            <Setter Property="AllowAutoHide" Value="False" />
        </Style>
        <Style Selector="ListBox#listBox ScrollBar">
            <Setter Property="AllowAutoHide" Value="False" />
        </Style>

        <!-- Match the Macros tab TreeView highlight: WPF-style blue tint
             on hover, translucent blue fill + accent border on selection.
             Same colors as Expander.hotkey-category ListBoxItem styles in
             DarkTheme.axaml so the two list panes look identical. -->
        <Style Selector="ListBox#listBox ListBoxItem">
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="2,1" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Transitions" Value="{x:Null}" />
        </Style>
        <Style Selector="ListBox#listBox ListBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="2,1" />
            <Setter Property="Transitions" Value="{x:Null}" />
        </Style>
        <Style Selector="ListBox#listBox ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1426A0DA" />
            <Setter Property="BorderBrush" Value="#26A0DA" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- Inactive selection (ListBox does not have keyboard focus): gray,
             matching the WPF MultiTrigger (IsSelected=True, IsKeyboardFocused=False)
             used by the Macros tab DraggableTreeView (see TreeViewItem:selected
             rule near line 982 of DarkTheme.axaml). -->
        <Style Selector="ListBox#listBox ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#4B4B4B" />
            <Setter Property="BorderBrush" Value="#C4C4C4" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="ListBox#listBox ListBoxItem:selected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4B4B4B" />
            <Setter Property="BorderBrush" Value="#C4C4C4" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- Active selection (ListBox has keyboard focus within): blue accent.
             Avalonia's :focus-within pseudo-class is the equivalent of WPF's
             IsKeyboardFocusWithin and overrides the inactive gray above. -->
        <Style Selector="ListBox#listBox:focus-within ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#1B3A52" />
            <Setter Property="BorderBrush" Value="#26A0DA" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="ListBox#listBox:focus-within ListBoxItem:selected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1B3A52" />
            <Setter Property="BorderBrush" Value="#26A0DA" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- Code editor (right pane): WPF reference uses the same dark
             fill as the rest of the surface and a 1-dip border. Force
             non-auto-hide scrollbars on the editor's internal ScrollViewer
             so vertical+horizontal bars are always reserved (matches WPF
             and stops code lines running under an overlaid bar). The
             AvalonEdit TextEditor exposes its own ScrollBar visibility,
             already set to Auto on the element. -->
        <Style Selector="avalonedit|TextEditor#CodeTextEditor">
            <Setter Property="Background" Value="#151515" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="avalonedit|TextEditor#CodeTextEditor ScrollViewer">
            <Setter Property="AllowAutoHide" Value="False" />
        </Style>
        <Style Selector="avalonedit|TextEditor#CodeTextEditor ScrollBar">
            <Setter Property="AllowAutoHide" Value="False" />
        </Style>

        <!-- "Learn how to contribute…" link. WPF Aero default Hyperlink:
             Foreground #FF0066CC, hover Foreground #FFEE0000 (red). The
             plain TextBlock + class lets us pin both states explicitly so
             the hover doesn't inherit some other red from a DynamicResource. -->
        <Style Selector="TextBlock.hyperlink">
            <Setter Property="Foreground" Value="#0066CC" />
        </Style>
        <Style Selector="TextBlock.hyperlink:pointerover">
            <Setter Property="Foreground" Value="#EE0000" />
        </Style>
    </UserControl.Styles>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="10,5,10,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.Styles>
                    <Style Selector="headered|HorizontalHeaderedContentControl">
                        <Setter Property="Margin" Value="0,0,10,0" />
                    </Style>
                    <Style Selector="controls2|ClearableComboBox">
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                    </Style>
                </Grid.Styles>
                <headered:HorizontalHeaderedContentControl Header="{x:Static resources:Strings.Shard}" Grid.Column="0">
                    <controls2:ClearableComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding Shards}" ClearCommand="{Binding ClearCommand}"
                                                 ClearCommandParameter="{x:Static data:FilterType.Shard}"
                                                 SelectedItem="{Binding ShardFilter}" />
                </headered:HorizontalHeaderedContentControl>
                <headered:HorizontalHeaderedContentControl Header="{x:Static resources:Strings.Era}" Grid.Column="1">
                    <controls2:ClearableComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding Eras}" ClearCommand="{Binding ClearCommand}"
                                                 ClearCommandParameter="{x:Static data:FilterType.Era}"
                                                 SelectedItem="{Binding EraFilter}" />
                </headered:HorizontalHeaderedContentControl>
                <headered:HorizontalHeaderedContentControl Header="{x:Static resources:Strings.Author}" Grid.Column="2">
                    <controls2:ClearableComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding Authors}" ClearCommand="{Binding ClearCommand}"
                                                 ClearCommandParameter="{x:Static data:FilterType.Author}"
                                                 SelectedItem="{Binding AuthorFilter}" />
                </headered:HorizontalHeaderedContentControl>
                <headered:HorizontalHeaderedContentControl Header="{x:Static resources:Strings.Category}" Margin="0"
                                                           Grid.Column="3">
                    <controls2:ClearableComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding Categories}"
                                                 ClearCommand="{Binding ClearCommand}"
                                                 ClearCommandParameter="{x:Static data:FilterType.Category}"
                                                 SelectedItem="{Binding CategoryFilter}" />
                </headered:HorizontalHeaderedContentControl>
            </Grid>
            <Grid Grid.Row="1" Margin="10,0,10,0" x:Name="SplitGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ListBox x:Name="listBox" ItemsSource="{Binding Macros}" Grid.Column="0" Grid.Row="0"
                             SelectedItem="{Binding SelectedItem}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" ToolTip.Tip="{Binding}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Grid.Row="1" Classes="hyperlink" TextWrapping="Wrap"
                               Text="{x:Static resources:Strings.Learn_how_to_contribute_your_own_macros___}"
                               TextDecorations="Underline"
                               Cursor="Hand" Tag="https://github.com/Reetus/ClassicAssist-Macros/blob/master/README.md"
                               PointerReleased="Hyperlink_RequestNavigate" />
                </Grid>
                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" />
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <avalonedit:TextEditor ShowLineNumbers="True" x:Name="CodeTextEditor" Grid.Row="0"
                                           HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                           FontFamily="Consolas" Margin="10,0,0,0" IsReadOnly="True">
                        <i:Interaction.Behaviors>
                            <behaviours:AvalonEditBehaviour
                                TextBinding="{Binding SelectedItem.Macro}" />
                        </i:Interaction.Behaviors>
                    </avalonedit:TextEditor>
                    <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="10,10,0,0">
                        <WrapPanel.Styles>
                            <Style Selector="Button">
                                <Setter Property="Margin" Value="0,0,10,0" />
                                <Setter Property="Padding" Value="10,5" />
                                <Setter Property="FontSize" Value="11" />
                            </Style>
                        </WrapPanel.Styles>
                        <ToggleButton x:Name="ToggleButton" Height="15" Margin="0" Classes="LeftRightIconToggleButton" VerticalAlignment="Center"
                                      IsCheckedChanged="ToggleButton_IsCheckedChanged" />
                        <Button Content="{x:Static resources:Strings.Copy_to_clipboard}"
                                Command="{Binding CopyToClipboardCommand}" CommandParameter="{Binding SelectedItem}" />
                        <Button Content="{x:Static resources:Strings.Create_Macro}"
                                Command="{Binding CreateMacroCommand}" CommandParameter="{Binding SelectedItem}" />
                        <Button Content="{x:Static resources:Strings.Open_in_Github}"
                                Command="{Binding OpenGithubCommand}"
                                CommandParameter="{Binding SelectedItem, ElementName=listBox}" />
                    </WrapPanel>
                </Grid>
            </Grid>
        </Grid>
        <ProgressBar Grid.Row="1" IsIndeterminate="True"
                     IsVisible="{Binding Loading, Converter={StaticResource BoolToIsVisibleConverter}}" />
    </Grid>
</UserControl>