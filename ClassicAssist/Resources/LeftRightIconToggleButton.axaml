<Styles xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:resources="clr-namespace:ClassicAssist.Shared.Resources;assembly=ClassicAssist.Shared">
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://ClassicAssist.Shared/Resources/Icons.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Styles.Resources>
    <Style Selector="ToggleButton.LeftRightIconToggleButton">
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="2,0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Name="Bg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            Cursor="Hand">
                        <!-- Use the same DrawingImage chevron resources WPF used. The
                             geometry is tall-and-narrow (~1:2 width:height ratio) which
                             gives the slim, tall caret shape rather than the chunky
                             Unicode glyph the TextBlock version produced. Image.Stretch
                             defaults to Uniform so it scales to the host ToggleButton's
                             Height (typically 15 in the macros tab). -->
                        <Image Name="Glyph"
                               Source="{StaticResource LeftChevron}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Stretch" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- When collapsed (IsChecked=True), flip the chevron to point right -->
    <Style Selector="ToggleButton.LeftRightIconToggleButton:checked /template/ Image#Glyph">
        <Setter Property="Source" Value="{StaticResource RightChevron}" />
    </Style>

    <Style Selector="ToggleButton.LeftRightIconToggleButton:pointerover /template/ Border#Bg">
        <Setter Property="Background" Value="#252525" />
    </Style>
</Styles>