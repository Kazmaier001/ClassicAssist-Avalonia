<UserControl x:Class="ClassicAssist.UI.Controls.SingleHueEntryControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             d:DesignHeight="20" d:DesignWidth="640">
    <!-- Stretches to fill the picker row (DockPanel.LastChild). MinWidth keeps a
         visible swatch even in narrow contexts. -->
    <Rectangle x:Name="HueRectangle" MinWidth="320" Height="16" Fill="Black"
               HorizontalAlignment="Stretch" />
</UserControl>
