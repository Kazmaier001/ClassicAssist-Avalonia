<UserControl x:Class="ClassicAssist.UI.Views.AboutControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:ClassicAssist.UI.ViewModels"
             xmlns:r="clr-namespace:ClassicAssist.Shared.Resources;assembly=ClassicAssist.Shared"
             xmlns:valueConverters="clr-namespace:ClassicAssist.UI.Misc.ValueConverters"
             xmlns:headered="clr-namespace:ClassicAssist.Controls.Headered;assembly=ClassicAssist.Controls"
             xmlns:controls="clr-namespace:ClassicAssist.Controls;assembly=ClassicAssist.Controls"
             d:DesignHeight="350" d:DesignWidth="600"
             d:DataContext="{d:DesignInstance {x:Type viewModels:AboutControlViewModel}, IsDesignTimeCreatable=True}">
    <UserControl.Styles>
        <StyleInclude Source="../../Resources/DarkTheme.axaml" />
    </UserControl.Styles>
    <UserControl.DataContext>
        <viewModels:AboutControlViewModel />
    </UserControl.DataContext>
    <!-- DesignStyle removed (WPF-only) -->
    <Grid>
        <Grid.Resources>
            <valueConverters:IntToHexStringValueConverter x:Key="IntToHexStringValueConverter" />
            <valueConverters:DateTimeToTimeSpanValueConverter x:Key="DateTimeToTimeSpanValueConverter" />
            <valueConverters:BoolToIsVisibleConverter x:Key="BoolToIsVisibleConverter" />
        </Grid.Resources>
        <Grid.Styles>
            <Style Selector="HeaderedContentControl">
                <Setter Property="Margin" Value="5" />
                <Setter Property="Padding" Value="5" />
            </Style>
            <Style Selector="TextBlock">
                <Setter Property="TextWrapping" Value="WrapWithOverflow" />
            </Style>
            <Style Selector="headered|HorizontalHeaderedContentControl">
                <Setter Property="HeaderMinWidth" Value="65" />
            </Style>
        </Grid.Styles>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <HeaderedContentControl Header="{x:Static r:Strings.Software}" Grid.Row="0" Grid.Column="0">
            <StackPanel>
                <headered:HorizontalHeaderedContentControl Header="{x:Static r:Strings.Product_}">
                    <TextBlock Text="{Binding Product}" />
                </headered:HorizontalHeaderedContentControl>
                <headered:HorizontalHeaderedContentControl Header="{x:Static r:Strings.Version_}">
                    <TextBlock Text="{Binding Version}" />
                </headered:HorizontalHeaderedContentControl>
                <headered:HorizontalHeaderedContentControl Header="{x:Static r:Strings.Build_Date_}">
                    <TextBlock Text="{Binding BuildDate}" />
                </headered:HorizontalHeaderedContentControl>
                <Grid Margin="5">
                    <TextBlock Text="{x:Static r:Strings.Made_For_Malo}" HorizontalAlignment="Center" FontWeight="Bold"
                               PointerEntered="TextBlock_MouseEnter" PointerExited="TextBlock_MouseLeave" Margin="0,10"
                               TextDecorations="Underline" />
                </Grid>
                <Button Content="{x:Static r:Strings.Project_Homepage}" Command="{Binding LaunchHomepageCommand}"
                        HorizontalAlignment="Stretch" Margin="0,10" />
            </StackPanel>
        </HeaderedContentControl>
        <HeaderedContentControl Header="{x:Static r:Strings.World_Status}" Grid.Row="0" Grid.Column="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <StackPanel.Styles>
                        <Style Selector="Button">
                            <Setter Property="Margin" Value="5" />
                            <Setter Property="Width" Value="150" />
                        </Style>
                    </StackPanel.Styles>
                    <headered:HorizontalHeaderedContentControl Header="{x:Static r:Strings.Connected_}">
                        <TextBlock
                            Text="{Binding ConnectedTime, Converter={StaticResource DateTimeToTimeSpanValueConverter}}"
                            IsVisible="{Binding Connected, Converter={StaticResource BoolToIsVisibleConverter}}" />
                    </headered:HorizontalHeaderedContentControl>
                    <headered:HorizontalHeaderedContentControl Header="{x:Static r:Strings.Items_}">
                        <TextBlock Text="{Binding ItemCount}" />
                    </headered:HorizontalHeaderedContentControl>
                    <headered:HorizontalHeaderedContentControl Header="{x:Static r:Strings.Mobiles_}">
                        <TextBlock Text="{Binding MobileCount}" />
                    </headered:HorizontalHeaderedContentControl>
                    <headered:HorizontalHeaderedContentControl Header="{x:Static r:Strings.Latency_}">
                        <!-- WPF used ContentStringFormat="{}{0}ms" on Label.
                             Avalonia Label / ContentControl doesn't have a
                             ContentStringFormat property, so format the value
                             at the binding level via TextBlock+StringFormat. -->
                        <TextBlock Text="{Binding Latency, StringFormat={}{0}ms}" />
                    </headered:HorizontalHeaderedContentControl>
                </StackPanel>
                <Button Content="{x:Static r:Strings.Show_World_Items}" IsEnabled="{Binding Connected}"
                        Command="{Binding ShowItemsCommand}" Margin="0,10" Grid.Row="1" />
            </Grid>
        </HeaderedContentControl>
        <HeaderedContentControl Header="{x:Static r:Strings.Misc}" Grid.Row="1" Grid.Column="0">
            <StackPanel Margin="10">
                <StackPanel.Styles>
                    <!-- IMPORTANT: type selector must be "Button" (not
                         "controls|ImageButton") because ImageButton has
                         StyleKeyOverride => typeof(Button). With the
                         ImageButton selector the Template setter never
                         matched, so the default Fluent Button template
                         (PART_ContentPresenter + #333333 Background) was
                         being used — visible as a colored square behind
                         the PayPal logo and no hover-border response. -->
                    <Style Selector="Button.paypal">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="controls:ImageButton">
                                    <!-- Explicit Background="Transparent" so the Border doesn't
                                         inherit/paint a button-hover fill behind the PayPal
                                         drawing (which itself is transparent except for the
                                         logo paths). Content binding is explicit so Avalonia
                                         routes the inherited Image into this ContentPresenter. -->
                                    <Border x:Name="Border" Background="Transparent"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1">
                                        <ContentPresenter x:Name="Content"
                                                          Content="{TemplateBinding Content}"
                                                          Background="Transparent"
                                                          BorderBrush="Transparent"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <!-- Suppress Fluent Button hover/press fill on the PayPal button itself
                         (StyleKeyOverride => Button means :pointerover / :pressed selectors
                         on Button apply to ImageButton and would paint a fill). -->
                    <!-- Hover indicator matching WPF original: ThemeBorderBrush
                         (#4B4B4B) outlines the button and the cursor becomes a
                         Hand so the click affordance is obvious. Background
                         stays transparent. Target the named Border directly —
                         relying on TemplateBinding{BorderBrush} can be beaten
                         by Avalonia's animator pulling in the global
                         "Button:pointerover" BorderBrush before our class
                         selector applies. -->
                    <Style Selector="Button.paypal:pointerover">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Cursor" Value="Hand" />
                    </Style>
                    <Style Selector="Button.paypal /template/ Border#Border">
                        <Setter Property="BorderBrush" Value="Transparent" />
                    </Style>
                    <Style Selector="Button.paypal:pointerover /template/ Border#Border">
                        <Setter Property="BorderBrush" Value="#4B4B4B" />
                    </Style>
                    <Style Selector="Button.paypal:pressed">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                    </Style>
                    <!-- The global "Button /template/ ContentPresenter" rule in
                         DarkTheme.axaml (line ~440) paints every Button's inner
                         ContentPresenter #333333 to match the WPF
                         ButtonBackgroundBrush. ImageButton has StyleKeyOverride =>
                         Button, so that rule applies to PayPal's custom template
                         and shows a #333333 square behind the transparent logo.
                         Force the ContentPresenter transparent for .paypal in all
                         pseudo-states. -->
                    <Style Selector="Button.paypal /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                    </Style>
                    <Style Selector="Button.paypal:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                    </Style>
                    <Style Selector="Button.paypal:pressed /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                    </Style>
                </StackPanel.Styles>
                <controls:ImageButton ImageHeight="50" MaxWidth="80" Classes="paypal"
                                      ToolTip.Tip="Donate to the upstream author (Reetus)"
                                      Command="{Binding OpenPayPalCommand}" ImageSource="{StaticResource PayPalIcon}" />
                <TextBlock
                    Text="Donate to the upstream author (Reetus). This Avalonia port relies on his work; your support is appreciated."
                    TextWrapping="Wrap" TextAlignment="Center" />
            </StackPanel>
        </HeaderedContentControl>
        <HeaderedContentControl Header="{x:Static r:Strings.Player}" Grid.Row="1" Grid.Column="1">
            <StackPanel>
                <headered:HorizontalHeaderedContentControl Header="{x:Static r:Strings.Shard_}">
                    <TextBlock Text="{Binding ShardName}" />
                </headered:HorizontalHeaderedContentControl>
                <headered:HorizontalHeaderedContentControl Header="{x:Static r:Strings.Features_}">
                    <TextBlock Text="{Binding ShardFeatures}" />
                </headered:HorizontalHeaderedContentControl>
                <headered:HorizontalHeaderedContentControl Header="{x:Static r:Strings.Name_}">
                    <TextBlock Text="{Binding PlayerName}" />
                </headered:HorizontalHeaderedContentControl>
                <headered:HorizontalHeaderedContentControl Header="{x:Static r:Strings.Serial_}">
                    <TextBlock
                        Text="{Binding PlayerSerial, Converter={StaticResource IntToHexStringValueConverter}}" />
                </headered:HorizontalHeaderedContentControl>
                <headered:HorizontalHeaderedContentControl Header="{x:Static r:Strings.Last_Target_}">
                    <TextBlock
                        Text="{Binding LastTargetSerial, Converter={StaticResource IntToHexStringValueConverter}}" />
                </headered:HorizontalHeaderedContentControl>
                <headered:HorizontalHeaderedContentControl Header="{x:Static r:Strings.Status_}">
                    <TextBlock Text="{Binding PlayerStatus}" />
                </headered:HorizontalHeaderedContentControl>
            </StackPanel>
        </HeaderedContentControl>
    </Grid>
</UserControl>