<Window x:Class="ClassicAssist.UI.Views.Autoloot.ClilocSelectionWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:resources="clr-namespace:ClassicAssist.Shared.Resources;assembly=ClassicAssist.Shared"
        xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Xaml.Behaviors.Interactivity"
        xmlns:autoloot="clr-namespace:ClassicAssist.UI.ViewModels.Autoloot"
        xmlns:behaviours="clr-namespace:ClassicAssist.Shared.UI.Behaviours;assembly=ClassicAssist.Shared"
        Title="{x:Static resources:Strings.Choose_by_Cliloc}" Height="350" Width="450"
        Background="{DynamicResource ThemeWindowBackgroundBrush}" Topmost="True">
    <Window.DataContext>
        <autoloot:ClilocSelectionViewModel />
    </Window.DataContext>
    <Window.Styles>
        <StyleInclude Source="../../../Resources/DarkTheme.axaml" />
    </Window.Styles>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBox Grid.Row="0" Text="{Binding FilterText}" />
            <DataGrid Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding FilteredClilocs}"
                      SelectedItem="{Binding SelectedCliloc}"
                      IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static resources:Strings.Property}" Width="300"
                                        Binding="{Binding Value}" />
                        <DataGridTextColumn Header="{x:Static resources:Strings.Cliloc}" Width="80"
                                        Binding="{Binding Key}" />
                    </DataGrid.Columns>
            </DataGrid>
        </Grid>
        <StackPanel Classes="dialog-buttons" Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10, 0, 0">
            <Button Content="{x:Static resources:Strings.OK}" Margin="0,0,5,0" Command="{Binding OKCommand}">
                <i:Interaction.Behaviors>
                    <behaviours:CloseOnClickBehaviour />
                </i:Interaction.Behaviors>
            </Button>
            <Button Content="{x:Static resources:Strings.Cancel}" Margin="5,0,0,0">
                <i:Interaction.Behaviors>
                    <behaviours:CloseOnClickBehaviour />
                </i:Interaction.Behaviors>
            </Button>
        </StackPanel>
    </Grid>
</Window>