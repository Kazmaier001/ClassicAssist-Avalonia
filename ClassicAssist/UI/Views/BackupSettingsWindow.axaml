<Window x:Class="ClassicAssist.UI.Views.BackupSettingsWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:viewModels="clr-namespace:ClassicAssist.UI.ViewModels"
        xmlns:resources="clr-namespace:ClassicAssist.Shared.Resources;assembly=ClassicAssist.Shared"
        xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Xaml.Behaviors.Interactivity"
        xmlns:behaviours="clr-namespace:ClassicAssist.Shared.UI.Behaviours;assembly=ClassicAssist.Shared"
        xmlns:validationRules="clr-namespace:ClassicAssist.Shared.UI.ValidationRules;assembly=ClassicAssist.Shared" Topmost="True"
        Title="{x:Static resources:Strings.Backup_Settings}" Width="400" SizeToContent="Height"
        Background="{DynamicResource ThemeWindowBackgroundBrush}">
    <Window.DataContext>
        <viewModels:BackupSettingsWindowViewModel />
    </Window.DataContext>
    <Window.Styles>
        <StyleInclude Source="../../Resources/DarkTheme.axaml" />
    </Window.Styles>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" Padding="10"
                Background="{DynamicResource ThemeBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.Styles>
                    <Style Selector="TextBlock.row-label">
                        <Setter Property="Width" Value="100" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                    <!-- IMPORTANT: selector must be class-scoped. A bare `DockPanel`
                         selector also matches DockPanels inside ComboBox / TextBox /
                         NumericUpDown templates (FluentTheme uses them internally),
                         which gave the inner TextBox a 10-px bottom margin, squeezed
                         the content area, and triggered the inner scrollbar. -->
                    <Style Selector="DockPanel.row">
                        <Setter Property="Margin" Value="0,0,0,10" />
                    </Style>
                </Grid.Styles>
                <DockPanel Grid.Row="0" Classes="row">
                    <TextBlock Classes="row-label" Text="{x:Static resources:Strings.Enabled}" DockPanel.Dock="Left" />
                    <CheckBox VerticalAlignment="Center" IsChecked="{Binding BackupOptions.Enabled}" />
                </DockPanel>
                <DockPanel Grid.Row="1" Classes="row">
                    <TextBlock Classes="row-label" Text="{x:Static resources:Strings.Incremental}" DockPanel.Dock="Left" />
                    <CheckBox VerticalAlignment="Center" IsChecked="{Binding BackupOptions.Provider.Incremental}"
                              ToolTip.Tip="{x:Static resources:Strings.Only_write_files_that_have_been_modified}" />
                </DockPanel>
                <DockPanel Grid.Row="2" Classes="row">
                    <TextBlock Classes="row-label" Text="{x:Static resources:Strings.Type}" DockPanel.Dock="Left" />
                    <ComboBox x:Name="comboBox" VerticalAlignment="Center" HorizontalAlignment="Stretch"
                              ItemsSource="{Binding Providers}"
                              SelectedItem="{Binding BackupOptions.Provider}" />
                </DockPanel>
                <ContentControl Grid.Row="3" Content="{Binding BackupOptions.Provider.LoginControl}" Margin="0,0,0,10"
                                IsVisible="{Binding BackupOptions.Provider.LoginControl, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <DockPanel Grid.Row="4" Classes="row">
                    <TextBlock Classes="row-label" Text="{x:Static resources:Strings.Backup_Days}" DockPanel.Dock="Left" />
                    <NumericUpDown FormatString="0" VerticalAlignment="Center" Value="{Binding BackupOptions.Days}"
                                        Background="{StaticResource ThemeBackgroundBrush}"
                                        Foreground="{StaticResource ThemeForegroundBrush}"
                                        BorderBrush="{StaticResource ThemeBorderBrush}"
                                        ToolTip.Tip="{x:Static resources:Strings.Setting_to_zero_will_cause_it_to_backup_on_every_client_close}" />
                </DockPanel>
                <DockPanel Grid.Row="5" Classes="row">
                    <TextBlock Classes="row-label" Text="{x:Static resources:Strings.Path}" DockPanel.Dock="Left" />
                    <Button Content="..." DockPanel.Dock="Right" Padding="5,0" Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Command="{Binding BrowsePathCommand}" />
                    <TextBox IsReadOnly="True" x:Name="TextBox" VerticalAlignment="Center"
                             Text="{Binding BackupOptions.Provider.BackupPath}" />
                </DockPanel>
            </Grid>
        </Border>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="1" Margin="0,10,0,0">
            <StackPanel.Styles>
                <Style Selector="Button">
                    <Setter Property="Margin" Value="5,0,0,0" />
                </Style>
            </StackPanel.Styles>
            <Button Content="{x:Static resources:Strings.Backup_Now}" Command="{Binding BackupNowCommand}" />
            <Button Content="{x:Static resources:Strings.Close}">
                <i:Interaction.Behaviors>
                    <behaviours:CloseOnClickBehaviour />
                </i:Interaction.Behaviors>
            </Button>
        </StackPanel>
    </Grid>
</Window>