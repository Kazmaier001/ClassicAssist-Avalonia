<UserControl x:Class="ClassicAssist.UI.Views.Debug.DebugVendorBuyControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:debug="clr-namespace:ClassicAssist.UI.ViewModels.Debug"
             xmlns:resources="clr-namespace:ClassicAssist.Shared.Resources;assembly=ClassicAssist.Shared"
             xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Xaml.Behaviors.Interactivity"
             xmlns:behaviours="clr-namespace:ClassicAssist.Shared.UI.Behaviours;assembly=ClassicAssist.Shared" Background="{DynamicResource ThemeBackgroundBrush}"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <debug:DebugVendorBuyViewModel />
    </UserControl.DataContext>
    <UserControl.Styles>
        <StyleInclude Source="Styles.axaml" />
        <StyleInclude Source="../../../Resources/DarkTheme.axaml" />
    </UserControl.Styles>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ListBox ItemsSource="{Binding Messages}">
            <i:Interaction.Behaviors>
                <behaviours:ItemsControlAutoScrollBehaviour />
            </i:Interaction.Behaviors>
        </ListBox>
        <CheckBox IsChecked="{Binding IsEnabled}" Content="{x:Static resources:Strings.Enabled}"
                  Margin="0,10,0,0" Grid.Row="1" />
    </Grid>
</UserControl>