<UserControl x:Name="userControl"
             x:Class="ClassicAssist.UI.Views.ECV.Settings.Controls.EditTextBlocks.HueEditTextBlock"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:ClassicAssist.Controls;assembly=ClassicAssist.Controls"
             d:DesignWidth="400">
    <controls:EditTextBlock ShowIcon="True" Label="{Binding Label, ElementName=userControl}"
                            Text="{Binding Hue, ElementName=userControl}" />
</UserControl>