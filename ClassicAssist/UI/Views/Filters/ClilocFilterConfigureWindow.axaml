<Window x:Class="ClassicAssist.UI.Views.Filters.ClilocFilterConfigureWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:resources="clr-namespace:ClassicAssist.Shared.Resources;assembly=ClassicAssist.Shared"
        xmlns:filters="clr-namespace:ClassicAssist.UI.ViewModels.Filters"
        xmlns:controls="clr-namespace:ClassicAssist.Controls;assembly=ClassicAssist.Controls"
        xmlns:valueConverters="clr-namespace:ClassicAssist.UI.Misc.ValueConverters"
        xmlns:misc="clr-namespace:ClassicAssist.Misc"
        xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Xaml.Behaviors.Interactivity"
        xmlns:behaviours="clr-namespace:ClassicAssist.Shared.UI.Behaviours;assembly=ClassicAssist.Shared" WindowStartupLocation="CenterScreen" Background="{DynamicResource ThemeWindowBackgroundBrush}"
        Title="{x:Static resources:Strings.Cliloc_Filter}" Height="450" Width="625">
    <Window.DataContext>
        <filters:ClilocFilterConfigureViewModel />
    </Window.DataContext>
    <Window.Resources>
        <ResourceDictionary>
            <valueConverters:CellWidthValueConverter x:Key="CellWidthValueConverter" />
            <misc:BindingProxy x:Key="Proxy" Data="{Binding}" />
            <filters:ClilocFilterConfigureViewModel x:Key="Dummy">
                <filters:ClilocFilterConfigureViewModel.Items>
                    <filters:FilterClilocEntry />
                </filters:ClilocFilterConfigureViewModel.Items>

            </filters:ClilocFilterConfigureViewModel>
        </ResourceDictionary>
    </Window.Resources>
    <Window.Styles>
        <StyleInclude Source="../../../Resources/DarkTheme.axaml" />
        <StyleInclude Source="../Debug/Styles.axaml" />
    </Window.Styles>
    <Grid Margin="10" d:DataContext="{StaticResource Dummy}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <controls:ImageButton ToolTip.Tip="{x:Static resources:Strings.Add}" Command="{Binding AddItemCommand}"
                                  ImageSource="{StaticResource AddIcon}" />
            <controls:ImageButton ToolTip.Tip="{x:Static resources:Strings.Remove}" Command="{Binding RemoveItemCommand}"
                                  CommandParameter="{Binding SelectedItem, ElementName=listView}"
                                  ImageSource="{StaticResource RemoveIcon}" />
        </StackPanel>
        <Grid Margin="0,10" Grid.Row="1">
            <DataGrid x:Name="listView" ItemsSource="{Binding Items}" Foreground="Black"
                      SelectedItem="{Binding SelectedItem}">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{x:Static resources:Strings.Remove}"
                                  Command="{Binding RemoveItemCommand}"
                                  CommandParameter="{Binding SelectedItem}" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="{x:Static resources:Strings.ID}" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type filters:FilterClilocEntry}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <controls:EditTextBlock Text="{Binding Cliloc, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                Grid.Column="0" VerticalAlignment="Center"
                                                                ShowIcon="True"
                                                                Foreground="{StaticResource ThemeForegroundBrush}" />
                                        <controls:ImageButton ImageSource="{StaticResource ExportIcon}"
                                                              ToolTip.Tip="{x:Static resources:Strings.Choose_by_Cliloc}"
                                                              HorizontalAlignment="Right" Grid.Column="1"
                                                              CommandParameter="{Binding}"
                                                              Command="{Binding Path=Data.ChooseClilocCommand, Source={StaticResource Proxy}}" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{x:Static resources:Strings.Original}" Width="150"
                                        Binding="{Binding Original}" />
                        <DataGridTemplateColumn Header="{x:Static resources:Strings.Replacement}" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="filters:FilterClilocEntry">
                                    <controls:EditTextBlock Foreground="{StaticResource ThemeForegroundBrush}"
                                                            Text="{Binding Replacement, Mode=TwoWay}"
                                                            MinWidth="100" ShowIcon="True"
 />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="{x:Static resources:Strings.Hue_Override}" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type filters:FilterClilocEntry}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <controls:EditTextBlock Text="{Binding Hue, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                Grid.Column="0" VerticalAlignment="Center"
                                                                ShowIcon="True"
                                                                Foreground="{StaticResource ThemeForegroundBrush}" />
                                        <controls:ImageButton ImageSource="{StaticResource ColorWheelIcon}"
                                                              HorizontalAlignment="Right" Grid.Column="1"
                                                              CommandParameter="{Binding}"
                                                              Command="{Binding Path=Data.SelectHueCommand, Source={StaticResource Proxy}}" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="{x:Static resources:Strings.Show_Overhead}" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type filters:FilterClilocEntry}">
                                    <CheckBox IsChecked="{Binding ShowOverhead}"
                                              ToolTip.Tip="{x:Static resources:Strings.Display_system_message_as_overhead_message}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns></DataGrid>
        </Grid>
        <StackPanel Classes="dialog-buttons" Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right">
            <Button Content="{x:Static resources:Strings.OK}" Command="{Binding OKCommand}" Margin="5">
                <i:Interaction.Behaviors>
                    <behaviours:CloseOnClickBehaviour />
                </i:Interaction.Behaviors>
            </Button>
            <Button Content="{x:Static resources:Strings.Cancel}" Margin="5">
                <i:Interaction.Behaviors>
                    <behaviours:CloseOnClickBehaviour />
                </i:Interaction.Behaviors>
            </Button>
        </StackPanel>
    </Grid>
</Window>