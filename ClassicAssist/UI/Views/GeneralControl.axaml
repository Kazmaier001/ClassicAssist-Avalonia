<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ValueConverters="clr-namespace:ClassicAssist.UI.Misc.ValueConverters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:r="clr-namespace:ClassicAssist.Shared.Resources;assembly=ClassicAssist.Shared"
    xmlns:viewModels="clr-namespace:ClassicAssist.UI.ViewModels"
    xmlns:misc="clr-namespace:ClassicAssist.Misc"
    xmlns:sharedConverters="clr-namespace:ClassicAssist.Shared.UI.ValueConverters;assembly=ClassicAssist.Shared"
    xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Xaml.Behaviors.Interactivity"
    xmlns:misc1="clr-namespace:ClassicAssist.UI.Misc"
    xmlns:behaviours="clr-namespace:ClassicAssist.UI.Misc.Behaviours"
    x:Name="userControl"
    x:Class="ClassicAssist.UI.Views.GeneralControl"
    d:DesignHeight="300" d:DesignWidth="500">
    <!-- DesignStyle removed (WPF-only) -->
    <UserControl.Resources>
        <ResourceDictionary>
            <ValueConverters:BoolToIsVisibleConverter x:Key="BoolToIsVisibleConverter" />
            <sharedConverters:StringToIntConverter x:Key="StringToIntConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <UserControl.Styles>
        <StyleInclude Source="../../Resources/DarkTheme.axaml" />
    </UserControl.Styles>
    <UserControl.DataContext>
        <viewModels:GeneralControlViewModel />
    </UserControl.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <HeaderedContentControl Grid.Column="0" Margin="5" BorderThickness="1" Header="{x:Static r:Strings.Filters}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ItemsControl x:Name="listBox" ItemsSource="{Binding Filters}" Grid.Row="0"
                              Background="{StaticResource ThemeInnerControlBackgroundBrush}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- DockPanel layout: gear pinned to the panel's right
                                 edge so every row's gear column-aligns regardless
                                 of label length. CheckBox.Content = the label, so
                                 the gap from box to text is exactly the CheckBox
                                 Padding (9.6 DIP = 12 device px at 125% DPI), with
                                 no extra TextBlock margin compounding on top. The
                                 CheckBox is the last (fill) child so its content
                                 area is clipped to (panel_width - 22) — long names
                                 like "Repeated Messages" stop at the gear instead
                                 of overflowing under it. -->
                            <DockPanel Margin="5,2.5" LastChildFill="True">
                                <Button DockPanel.Dock="Right" Width="22"
                                        Background="Transparent" BorderThickness="0"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        ToolTip.Tip="{x:Static r:Strings.Options}"
                                        IsVisible="{Binding IsConfigurable, Converter={StaticResource BoolToIsVisibleConverter}}"
                                        Command="{Binding DataContext.ConfigureFilterCommand, ElementName=userControl}"
                                        CommandParameter="{Binding Mode=OneWay}" Margin="0" Padding="0">
                                    <Image Source="{StaticResource configureIcon}" Height="16" Margin="0" />
                                </Button>
                                <CheckBox IsChecked="{Binding Enabled}"
                                          Content="{Binding Name}"
                                          ClipToBounds="True" />
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Grid Grid.Row="1" Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Label Content="{x:Static r:Strings.Light}" Grid.Column="0"
                           VerticalAlignment="Center" VerticalContentAlignment="Center" Padding="0,0,5,0" />
                    <Slider Grid.Column="1" Maximum="31"
                            Value="{Binding Options.LightLevel, Mode=TwoWay}"
                            IsDirectionReversed="True" Minimum="0" Height="20" VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </HeaderedContentControl>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <HeaderedContentControl Header="{x:Static r:Strings.Options}" Grid.Row="0" Margin="5">
                <StackPanel Margin="5">
                    <CheckBox Content="{x:Static r:Strings.Always_On_Top}"
                              IsChecked="{Binding CurrentOptions.AlwaysOnTop}" />
                    <CheckBox Content="{x:Static r:Strings.Minimize_to_system_tray}"
                              IsChecked="{Binding Options.SysTray}" />
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Resources>
                            <misc:BindingProxy x:Key="proxy" Data="{Binding}" />
                        </StackPanel.Resources>
                        <CheckBox IsChecked="{Binding Options.ActionDelay}" DataContext="{Binding}">
                            <CheckBox.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Label Content="{x:Static r:Strings.Action_Delay_}" Margin="0" Padding="0" VerticalAlignment="Center" />
                                        <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                                        <!-- StringToIntConverter + LostFocus guards against
                                             the InvalidCastException that Avalonia raises when
                                             the user clears the field (empty string → int). -->
                                        <TextBox Width="40" Margin="10,0,10,0"
                                                 Text="{Binding Path=Data.Options.ActionDelayMS, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource StringToIntConverter}, Source={StaticResource proxy}}" />
                                        <Label Content="ms" Margin="0" Padding="0" />
                                    </StackPanel>
                                </DataTemplate>
                            </CheckBox.ContentTemplate>
                        </CheckBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Resources>
                            <misc:BindingProxy x:Key="proxy" Data="{Binding}" />
                        </StackPanel.Resources>
                        <CheckBox IsChecked="{Binding Options.DragDelay}" DataContext="{Binding}">
                            <CheckBox.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Label Content="{x:Static r:Strings.Action_Delay_Dragging__Sphere_X__}" Margin="0" Padding="0" VerticalAlignment="Center" />
                                        <!-- ReSharper disable once Xaml.BindingWithContextNotResolved -->
                                        <TextBox Width="40" Margin="10,0,10,0"
                                                 Text="{Binding Path=Data.Options.DragDelayMS, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource StringToIntConverter}, Source={StaticResource proxy}}" />
                                        <Label Content="ms" Margin="0" Padding="0" />
                                    </StackPanel>
                                </DataTemplate>
                            </CheckBox.ContentTemplate>
                        </CheckBox>
                    </StackPanel>
                </StackPanel>
            </HeaderedContentControl>
            <Control Grid.Row="1" />
            <Grid Grid.Row="2">
                <HeaderedContentControl Header="{x:Static r:Strings.Saved_Passwords_}" Margin="5" Padding="5">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Content="{x:Static r:Strings.Enabled}" Grid.Column="0"
                                      IsChecked="{Binding SavePasswords}" />
                            <ComboBox x:Name="comboBox" Grid.Column="1" Margin="5,0,5,0" SelectedIndex="0"
                                      HorizontalAlignment="Stretch"
                                      Height="28"
                                      Background="#333333"
                                      ItemsSource="{Binding SavedPasswords}" />
                            <Button Content="{x:Static r:Strings.Remove}" Grid.Column="2"
                                    Padding="10,3" Height="28"
                                    VerticalContentAlignment="Center"
                                    Command="{Binding RemoveSavedPasswordCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=comboBox}" />
                        </Grid>
                        <CheckBox Content="{x:Static r:Strings.Only_overwrite_blank_password}"
                                  IsChecked="{Binding SavePasswordsOnlyBlank}" />
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="{x:Static r:Strings.Autologin}"
                                      IsChecked="{Binding Options.Autologin}" />
                            <Button Content="..." Command="{Binding AutologinConfigureCommand}" Margin="5,0,0,0"
                                    Padding="10,0" IsEnabled="{Binding Options.Autologin}" />
                        </StackPanel>
                    </StackPanel>
                </HeaderedContentControl>
            </Grid>
            <Grid Grid.Row="3">
                <HeaderedContentControl Header="{x:Static r:Strings.Profiles}" Margin="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="5">
                            <ComboBox HorizontalAlignment="Stretch"
                                      Height="28"
                                      Background="#333333"
                                      ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}">
                                <i:Interaction.Behaviors>
                                    <behaviours:ComboBoxBehavior CommandBinding="{Binding ChangeProfileCommand}"
                                                            OnlyUserTriggered="True" />
                                </i:Interaction.Behaviors>
                            </ComboBox>
                        </Grid>
                        <DockPanel Grid.Column="1" Margin="0,5,5,5">
                            <Button Content="{x:Static r:Strings.New}" Margin="0,0,5,0" Padding="10,3"
                                    Height="28" VerticalContentAlignment="Center"
                                    Command="{Binding NewProfileCommand}" />
                            <Button Content="{x:Static r:Strings.Save}" Margin="0,0,5,0" Padding="10,3"
                                    Height="28" VerticalContentAlignment="Center"
                                    Command="{Binding SaveProfileCommand}" />
                            <Button Command="{Binding LinkUnlinkProfileCommand}" Padding="4"
                                    Height="28"
                                    ToolTip.Tip="{Binding LinkUnlinkTooltip}">
                                <Grid>
                                    <Image Width="16" Margin="3,0,3,0"
                                           Source="{DynamicResource unlinkedIcon}"
                                           IsVisible="{Binding !IsLinkedProfile}" />
                                    <Image Width="16" Margin="3,0,3,0"
                                           Source="{DynamicResource linkedIcon}"
                                           IsVisible="{Binding IsLinkedProfile}" />
                                </Grid>
                            </Button>
                            <Button Command="{Binding BackupSettingsCommand}" Margin="5,0,0,0" Padding="4"
                                    Height="28">
                                <Image Width="16" Source="{DynamicResource BackupIcon}"
                                       ToolTip.Tip="{x:Static r:Strings.Backup_Settings}" />
                            </Button>
                        </DockPanel>
                    </Grid>
                </HeaderedContentControl>
            </Grid>
        </Grid>
    </Grid>
</UserControl>