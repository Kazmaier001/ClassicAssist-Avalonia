<Window x:Class="ClassicAssist.UI.Views.SplashWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ClassicAssist.UI.Views"
        xmlns:resources="clr-namespace:ClassicAssist.Shared.Resources;assembly=ClassicAssist.Shared" WindowStartupLocation="CenterScreen" Background="Transparent"
        SystemDecorations="None" TransparencyLevelHint="Transparent" SizeToContent="WidthAndHeight" ShowInTaskbar="False"
        Title="{x:Static resources:Strings.ProductName}" Topmost="True">
    <Image x:Name="SplashImage" Opacity="0.9" Stretch="None" />
</Window>